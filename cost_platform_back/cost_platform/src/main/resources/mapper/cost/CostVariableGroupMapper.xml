<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.cost.CostVariableGroupMapper">

    <resultMap id="CostVariableGroupResult" type="com.ruoyi.system.domain.cost.CostVariableGroup">
        <id property="groupId" column="group_id" />
        <result property="sceneId" column="scene_id" />
        <result property="sceneCode" column="scene_code" />
        <result property="sceneName" column="scene_name" />
        <result property="businessDomain" column="business_domain" />
        <result property="groupCode" column="group_code" />
        <result property="groupName" column="group_name" />
        <result property="sortNo" column="sort_no" />
        <result property="status" column="status" />
        <result property="remark" column="remark" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <sql id="selectVariableGroupVo">
        select g.group_id,
               g.scene_id,
               s.scene_code,
               s.scene_name,
               s.business_domain,
               g.group_code,
               g.group_name,
               g.sort_no,
               g.status,
               g.remark,
               g.create_by,
               g.create_time,
               g.update_by,
               g.update_time
        from cost_variable_group g
        left join cost_scene s on s.scene_id = g.scene_id
    </sql>

    <sql id="groupWhere">
        <where>
            <if test="sceneId != null">
                and g.scene_id = #{sceneId}
            </if>
            <if test="businessDomain != null and businessDomain != ''">
                and s.business_domain = #{businessDomain}
            </if>
            <if test="keyword != null and keyword != ''">
                and (
                    g.group_code like concat('%', #{keyword}, '%')
                    or g.group_name like concat('%', #{keyword}, '%')
                )
            </if>
            <if test="groupCode != null and groupCode != ''">
                and g.group_code like concat('%', #{groupCode}, '%')
            </if>
            <if test="groupName != null and groupName != ''">
                and g.group_name like concat('%', #{groupName}, '%')
            </if>
            <if test="status != null and status != ''">
                and g.status = #{status}
            </if>
        </where>
    </sql>

    <select id="selectVariableGroupList" parameterType="com.ruoyi.system.domain.cost.CostVariableGroup" resultMap="CostVariableGroupResult">
        <include refid="selectVariableGroupVo"/>
        <include refid="groupWhere"/>
        order by s.scene_name asc, g.sort_no asc, g.group_id asc
    </select>

    <select id="selectVariableGroupOptions" parameterType="com.ruoyi.system.domain.cost.CostVariableGroup" resultMap="CostVariableGroupResult">
        <include refid="selectVariableGroupVo"/>
        <include refid="groupWhere"/>
        order by s.scene_name asc, g.sort_no asc, g.group_id asc
    </select>

</mapper>
